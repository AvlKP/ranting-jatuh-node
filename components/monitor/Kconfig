menu "Monitor"

config MONITOR_STORAGE_MINUTES
    int "Tilt data storage minutes"
    default 5
    range 1 60
    help
        Number of minutes of tilt data stored for statistics and FFT.

config MONITOR_IMU_RATE_HZ
    int "IMU sampling rate (Hz)"
    default 26
    range 1 208
    help
        Target IMU sampling rate in Hz for monitor processing loop.

choice MONITOR_AE_MODE
    prompt "Acoustic emission mode"
    default MONITOR_AE_MODE_GPIO
    help
        Select acoustic emission failure detection mode.

config MONITOR_AE_MODE_GPIO
    bool "GPIO interrupt (digital)"

config MONITOR_AE_MODE_ADC
    bool "ADC threshold (analog)"

endchoice

config MONITOR_AE_ADC_THRESHOLD
    int "AE ADC threshold"
    default 3000
    range 0 4095
    help
        Raw ADC threshold for acoustic emission failure.

config MONITOR_PEAK_MIN_AMPLITUDE
    int "Peak detection min amplitude (deg)"
    default 2
    range 0 90
    help
        Minimum peak amplitude in degrees for sway and damping detection.

config MONITOR_PEAK_MIN_SPACING_SAMPLES
    int "Peak detection min spacing (samples)"
    default 5
    range 1 500
    help
        Minimum sample spacing between peaks for sway and damping detection.

config MONITOR_FREEFALL_THS
    int "Free-fall threshold (raw)"
    default 3
    range 1 7
    help
        LSM6DS3 free-fall threshold (register value).

config MONITOR_FF_DUR
    int "Free-fall duration (FF_DUR)"
    default 5
    range 0 31
    help
        Free-fall duration event. Duration = FF_DUR + 1 in ODR cycles.
        Each LSB extends duration by 1 ODR.

config MONITOR_TARE_ENABLE
    bool "Enable tilt taring at startup"
    default y
    help
        Calculates and subtracts baseline tilt (roll/pitch) offset at startup.

config MONITOR_TARE_SAMPLES
    int "Tilt tare sample count"
    default 100
    range 10 1000
    help
        Number of initial samples to average for the baseline tare offset calculation.

config MONITOR_FFT_DE_MEAN_ENABLE
    bool "Enable de-meaning/zero-centering of FFT input"
    default y
    help
        Removes the mean (DC component) from input tilt vector before performing FFT to avoid a 0Hz peak.

config MONITOR_SHORT_BUFFER_SIZE
    int "Short buffer size for variance"
    default 256
    range 10 1024
    help
        Size of the short buffer to compute live variance for IDLE/DISTURBED transitions.

config MONITOR_K_IDLE_X100
    int "IDLE to DISTURBED variance threshold multiplier (x100)"
    default 150
    range 100 1000
    help
        Multiplier (scaled by 100) for IDLE variance. E.g., 150 means short variance must exceed 1.5x of the 5-min IDLE variance.

config MONITOR_K_DISTURBED_X100
    int "DISTURBED to IDLE variance threshold multiplier (x100)"
    default 110
    range 50 1000
    help
        Multiplier (scaled by 100) for IDLE variance. E.g., 110 means short variance must fall below 1.1x of the 5-min IDLE variance.

config MONITOR_N_DPAD
    int "DISTURBED buffer refresh margin (samples)"
    default 100
    range 10 1000
    help
        Number of samples before the 5-min buffer is full at which the buffer will be refreshed during a prolonged DISTURBED state.

endmenu


