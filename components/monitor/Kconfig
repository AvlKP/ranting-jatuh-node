menu "Monitor"

config MONITOR_STORAGE_MINUTES
    int "Tilt data storage minutes"
    default 5
    range 1 60
    help
        Number of minutes of tilt data stored for statistics and FFT.

config MONITOR_IMU_RATE_HZ
    int "IMU sampling rate (Hz)"
    default 52
    range 1 208
    help
        Target IMU sampling rate in Hz for monitor processing loop.

choice MONITOR_AE_MODE
    prompt "Acoustic emission mode"
    default MONITOR_AE_MODE_GPIO
    help
        Select acoustic emission failure detection mode.

config MONITOR_AE_MODE_GPIO
    bool "GPIO interrupt (digital)"

config MONITOR_AE_MODE_ADC
    bool "ADC threshold (analog)"

endchoice

config MONITOR_AE_ADC_THRESHOLD
    int "AE ADC threshold"
    default 3000
    range 0 4095
    help
        Raw ADC threshold for acoustic emission failure.

config MONITOR_PEAK_MIN_AMPLITUDE_X10
    int "Peak detection min amplitude (deg x10)"
    default 5
    range 1 900
    help
        Minimum peak amplitude in degrees (scaled by 10) for sway and damping detection.

config MONITOR_PEAK_MIN_SPACING_SAMPLES
    int "Peak detection min spacing (samples)"
    default 2
    range 1 500
    help
        Minimum sample spacing between peaks for sway and damping detection.

config MONITOR_CENTERLINE_MIN_AMPLITUDE_X100
    int "Centerline pair min amplitude (deg x100)"
    default 5
    range 1 9000
    help
        Minimum half peak-to-peak amplitude in degrees (scaled by 100) for
        centerline modal analysis.

config MONITOR_CENTERLINE_LOBE_REVERSAL_X100
    int "Centerline lobe reversal threshold (deg x100)"
    default 10
    range 1 9000
    help
        Minimum opposite-extrema reversal in degrees (scaled by 100) before
        lobe collapse starts a new peak/trough lobe.

config MONITOR_MODAL_FREQ_MIN_HZ_X10
    int "Modal FFT minimum frequency (Hz x10)"
    default 5
    range 0 1000
    help
        Minimum non-DC FFT frequency in Hz (scaled by 10) eligible for modal
        natural-frequency selection.

config MONITOR_MODAL_FREQ_MAX_HZ_X10
    int "Modal FFT maximum frequency (Hz x10)"
    default 120
    range 1 2000
    help
        Maximum FFT frequency in Hz (scaled by 10) eligible for modal
        natural-frequency selection.

config MONITOR_DSP_TKEO_HIGH_X10
    int "DSP TKEO high threshold (x10)"
    default 400
    range 1 100000
    help
        Streaming gyro-magnitude TKEO threshold for entering DISTURBED.
        Default 400 means 40.0.

config MONITOR_DSP_TKEO_LOW_X10
    int "DSP TKEO low threshold (x10)"
    default 50
    range 0 100000
    help
        Streaming gyro-magnitude TKEO quiet threshold for DISTURBED exit.
        Default 50 means 5.0.

config MONITOR_DSP_GMAG_ONSET_X100
    int "DSP gyro magnitude onset threshold (dps x100)"
    default 200
    range 0 100000
    help
        Calibrated gyro magnitude threshold for entering DISTURBED.
        Default 200 means 2.0 dps.

config MONITOR_DSP_GMAG_QUIET_X100
    int "DSP gyro magnitude quiet threshold (dps x100)"
    default 150
    range 0 100000
    help
        Calibrated gyro magnitude threshold for quiet debounce.
        Default 150 means 1.5 dps.

config MONITOR_FREEFALL_THS
    int "Free-fall threshold (raw)"
    default 3
    range 1 7
    help
        LSM6DS3 free-fall threshold (register value).

config MONITOR_FF_DUR
    int "Free-fall duration (FF_DUR)"
    default 5
    range 0 31
    help
        Free-fall duration event. Duration = FF_DUR + 1 in ODR cycles.
        Each LSB extends duration by 1 ODR.

config MONITOR_TARE_ENABLE
    bool "Enable tilt taring at startup"
    default y
    help
        Calculates and subtracts baseline tilt (roll/pitch) offset at startup.

config MONITOR_TARE_SAMPLES
    int "Tilt tare sample count"
    default 100
    range 10 1000
    help
        Number of initial samples to average for the baseline tare offset calculation.

config MONITOR_TARE_SETTLE_SAMPLES
    int "Tilt tare settling sample count"
    default 500
    range 0 5000
    help
        Number of initial samples to discard at startup to allow the Madgwick/Complementary filter to converge before taring.

config MONITOR_FFT_DE_MEAN_ENABLE
    bool "Enable de-meaning/zero-centering of FFT input"
    default y
    help
        Removes the mean (DC component) from input tilt vector before performing FFT to avoid a 0Hz peak.

config MONITOR_SHORT_BUFFER_SIZE
    int "Short buffer size for variance"
    default 256
    range 10 1024
    help
        Size of the short buffer to compute live variance for IDLE/DISTURBED transitions.

# @deprecated Legacy variance-based IDLE detection. No longer used by any code.
# Replaced by CONFIG_MONITOR_DSP_TKEO_HIGH_X10 and DspDisturbanceDetector.
config MONITOR_K_IDLE_X100
    int "IDLE to DISTURBED variance threshold multiplier (x100)"
    default 150
    range 100 1000
    help
        Multiplier (scaled by 100) for IDLE variance. E.g., 150 means short variance must exceed 1.5x of the 5-min IDLE variance.

# @deprecated Legacy variance-based DISTURBED detection. No longer used by any code.
# Replaced by CONFIG_MONITOR_DSP_TKEO_LOW_X10 and DspDisturbanceDetector.
config MONITOR_K_DISTURBED_X100
    int "DISTURBED to IDLE variance threshold multiplier (x100)"
    default 110
    range 50 1000
    help
        Multiplier (scaled by 100) for IDLE variance. E.g., 110 means short variance must fall below 1.1x of the 5-min IDLE variance.

# @deprecated Legacy absolute minimum variance floor. No longer used by any code.
# Replaced by DspDisturbanceDetector which uses TKEO + gmag thresholds.
config MONITOR_ABS_MIN_VAR_X10000
    int "Absolute minimum variance floor (x10000)"
    default 50
    range 1 10000
    help
        Absolute minimum variance floor (scaled by 10000). E.g., 50 means absolute floor is 0.005 deg^2. Used to prevent false transitions on very still devices.

config MONITOR_N_DPAD
    int "DISTURBED buffer refresh margin (samples)"
    default 100
    range 10 1000
    help
        Number of samples before the 5-min buffer is full at which the buffer will be refreshed during a prolonged DISTURBED state.

config MONITOR_IMU_CALIBRATION
    bool "Enable IMU bias calibration"
    default y
    help
        When enabled, static accel/gyro biases are read from NVS and subtracted
        from raw IMU values before filter processing. Biases default to zero if
        NVS key missing.

config MONITOR_DISTURBED_EXIT_DEBOUNCE
    int "DISTURBED to IDLE exit debounce count (samples)"
    default 64
    range 1 1000
    help
        Number of consecutive samples below the low threshold to transition to IDLE.

config MONITOR_DEBUG_DUMP
    bool "Enable debug data dump to SD card"
    default n
    help
        When enabled, intermediate FFT/decay region/peak/damping data is dumped
        to /sdcard/dbg_dump.csv on each DISTURBED->IDLE transition for offline
        analysis with scripts/debug_analyze.py.

endmenu



