      "strokeWidth": 2, "roundness": {"type": 3},
      "fillStyle": "solid", "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "realtime-label",
      "type": "text",
      "x": 440, "y": 182, "width": 310, "height": 25,
      "text": "PLANE 1: REAL-TIME DETECTION [O(1)/sample]",
      "fontSize": 14, "fontFamily": 1,
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "tkeo-box",
      "type": "rectangle",
      "x": 460, "y": 215, "width": 260, "height": 50,
      "strokeColor": "#c2410c", "backgroundColor": "#fed7aa",
      "strokeWidth": 1.5, "roundness": {"type": 3},
      "fillStyle": "solid", "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "tkeo-text",
      "type": "text",
      "x": 470, "y": 218, "width": 240, "height": 45,
      "text": "Teager-Kaiser Energy Operator\npsi[n] = x[n-1]^2 - x[n-2]*x[n]\n3-sample window, 1-sample latency",
      "fontSize": 11, "fontFamily": 1, "textAlign": "center",
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "schmitt-box",
      "type": "rectangle",
      "x": 460, "y": 285, "width": 260, "height": 110,
      "strokeColor": "#c2410c", "backgroundColor": "#fed7aa",
      "strokeWidth": 1.5, "roundness": {"type": 3},
      "fillStyle": "solid", "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "schmitt-text",
      "type": "text",
      "x": 470, "y": 288, "width": 240, "height": 104,
      "text": "Schmitt Trigger State Machine\n\n  IDLE --(psi>hi OR |g|>onset)--> DISTURBED\n  DISTURBED --(psi<lo AND |g|<quiet)--> IDLE\n\n  Hysteresis + debounced exit (N quiet)\n  Pause-on-boundary prevents chatter",
      "fontSize": 10, "fontFamily": 1, "textAlign": "left",
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "buffer-box",
      "type": "rectangle",
      "x": 460, "y": 410, "width": 260, "height": 35,
      "strokeColor": "#c2410c", "backgroundColor": "#fed7aa",
      "strokeWidth": 1.5, "roundness": {"type": 3},
      "fillStyle": "solid", "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "buffer-text",
      "type": "text",
      "x": 470, "y": 416, "width": 240, "height": 25,
      "text": "Disturbance Buffer (roll, pitch, gmag, gyro, accel)",
      "fontSize": 11, "fontFamily": 1, "textAlign": "center",
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "bg-posthoc",
