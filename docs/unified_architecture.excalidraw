      "type": "text",
      "x": 90, "y": 918, "width": 210, "height": 70,
      "text": "Auxiliary Parameters\nTilt: atan2(accel) values\nSway stats: max & mean p-p\nIDLE baseline: mean, variance",
      "fontSize": 10, "fontFamily": 1, "textAlign": "left",
      "strokeStyle": "solid", "opacity": 100
    },
