    },
    {
      "id": "compf-text",
      "type": "text",
      "x": 90, "y": 278, "width": 240, "height": 55,
      "text": "Adaptive Complementary Filter\ntheta = a*int(g) + (1-a)*atan2(a)\nalpha auto-tunes on |accel| near 1g",
      "fontSize": 11, "fontFamily": 1, "textAlign": "center",
      "strokeStyle": "solid", "opacity": 100
