      "type": "text",
      "x": 60, "y": 492, "width": 450, "height": 25,
      "text": "PLANE 2: POST-HOC MODAL ANALYSIS [triggered on DISTURBED -> IDLE]",
      "fontSize": 14, "fontFamily": 1,
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "classify-box",
      "type": "rectangle",
      "x": 80, "y": 525, "width": 230, "height": 70,
