      "strokeWidth": 1.5, "roundness": {"type": 3},
      "fillStyle": "solid", "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "classify-text",
      "type": "text",
      "x": 90, "y": 528, "width": 210, "height": 65,
      "text": "[FROM PYTHON] Event Classification\n\npeak>=20 -> pull_release\n>=8 dur>80 -> oscillation\n<8 dur<80 -> flick\n<8 dur>=80 -> pull_hold",
      "fontSize": 10, "fontFamily": 1, "textAlign": "left",
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "dynamic-box",
      "type": "rectangle",
      "x": 340, "y": 530, "width": 100, "height": 60,
