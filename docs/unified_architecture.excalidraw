    {
      "id": "gmag-text",
      "type": "text",
      "x": 90, "y": 413, "width": 240, "height": 25,
      "text": "Gyro Magnitude: |g| = sqrt(gx2+gy2+gz2)",
      "fontSize": 11, "fontFamily": 1, "textAlign": "center",
      "strokeStyle": "solid", "opacity": 100
    },
    {
      "id": "bg-realtime",
      "type": "rectangle",
      "x": 420, "y": 180, "width": 340, "height": 280,
