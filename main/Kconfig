menu "Application Storage"

choice APP_SD_INTERFACE
    prompt "SD card interface"
    default APP_SD_INTERFACE_SDMMC

config APP_SD_INTERFACE_SDMMC
    bool "SDMMC 1-bit"

config APP_SD_INTERFACE_SPI
    bool "SPI (SDSPI)"

endchoice

config APP_SD_MOUNT_POINT
    string "SD card mount point"
    default "/sdcard"

endmenu

menu "Application Verification"

config APP_VERIFY_ENABLE
    bool "Enable startup verification"
    default y

config APP_VERIFY_MQTT_TOPIC
    string "MQTT verify topic suffix"
    default "verify"
    help
        MQTT topic suffix for startup verification publish.
        The full topic is constructed as ranting/{node_id}/{suffix} at runtime.
        The {node_id} is resolved from CONFIG_LOGGER_NODE_ID, NVS, or auto-generated.

config APP_VERIFY_MONITOR_TIMEOUT_MS
    int "Monitor verify timeout (ms)"
    default 5000
    range 100 600000

endmenu

menu "Debug Configuration"

config APP_DEBUG_CSV_LOGS
    bool "Enable CSV debug logs for accel and tilt"
    default n
    help
      If enabled, acceleration and tilt data will be logged to a CSV file
      on the SD card and excluded from server transmission. This helps with
      offline manual analysis.

endmenu
