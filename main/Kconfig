menu "Application Storage"

choice APP_SD_INTERFACE
    prompt "SD card interface"
    default APP_SD_INTERFACE_SDMMC

config APP_SD_INTERFACE_SDMMC
    bool "SDMMC 1-bit"

config APP_SD_INTERFACE_SPI
    bool "SPI (SDSPI)"

endchoice

config APP_SD_MOUNT_POINT
    string "SD card mount point"
    default "/sdcard"

endmenu

menu "Application Verification"

config APP_VERIFY_ENABLE
    bool "Enable startup verification"
    default y

config APP_VERIFY_MQTT_TOPIC
    string "MQTT verify topic"
    default "ranting/verify"

config APP_VERIFY_MONITOR_TIMEOUT_MS
    int "Monitor verify timeout (ms)"
    default 5000
    range 100 600000

endmenu
