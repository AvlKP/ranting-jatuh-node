CompileFlags:
  # Tells clangd to look in the build/ directory for compile_commands.json
  # which is automatically generated by ESP-IDF's CMake build system.
  CompilationDatabase: "build"
  Add:
    # ESP-IDF relies on GCC-specific attributes and pragmas that Clang does not 
    # always recognize. Suppressing these warnings keeps the UI clean.
    - "-Wno-unknown-attributes"
    - "-Wno-unknown-pragmas"
    - "-Wno-unused-command-line-argument"
    
    # Explicitly define ESP_PLATFORM to help with deep framework header resolution
    - "-DESP_PLATFORM"

    # If you are using C++20 (supported in ESP-IDF v5.x), uncomment below:
    - "-std=gnu++20"

  Remove:
    - "-fno-shrink-wrap"
    - "-fstrict-volatile-bitfields"
    - "-fno-tree-switch-conversion"
    # You may also want to remove this one, as it commonly causes warnings with ESP32 XTensa targets:
    - "-mlongcalls"

Index:
  # Enables background indexing of the ESP-IDF components for faster Go-To-Definition
  Background: Build

Diagnostics:
  # Suppress specific diagnostics that commonly conflict with ESP-IDF macros
  # or FreeRTOS C-style paradigms when writing C++ wrappers.
  Suppress:
    - "modernize-use-trailing-return-type"